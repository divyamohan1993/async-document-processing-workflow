# =============================================================================
# Async Document Processing Workflow System - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment.
# NEVER commit the .env file to version control.
# =============================================================================

# --- Application ---
# Set to true for development, false for production
DEBUG=false
# Secret key for JWT token signing - MUST be changed in production (min 32 chars)
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
# Domain name for the application (used for CORS and SSL)
DOMAIN=localhost

# --- PostgreSQL ---
POSTGRES_USER=postgres
# MUST be changed in production - use a strong, unique password
POSTGRES_PASSWORD=your-secure-db-password-here
POSTGRES_DB=docprocess

# --- Redis ---
# MUST be changed in production - use a strong, unique password
REDIS_PASSWORD=your-secure-redis-password-here

# --- Celery Flower (Task Monitoring Dashboard) ---
FLOWER_USER=admin
# MUST be changed in production
FLOWER_PASSWORD=change-this-flower-password

# --- Frontend ---
# URL the frontend uses to reach the backend API
# In production behind Nginx, this should be https://your-domain.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost/api/v1

# --- File Upload ---
# Maximum file size in bytes (default: 50MB = 52428800)
MAX_FILE_SIZE=52428800
